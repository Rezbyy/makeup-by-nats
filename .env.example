# ─────────────────────────────────────────────────────────────────────────────
# Makeup by Nats — Environment Variables
#
# SETUP STEPS:
#   1. Copy this file and rename the copy to exactly:  .env
#   2. Fill in your real values below
#   3. NEVER share or commit the .env file — it contains your password
# ─────────────────────────────────────────────────────────────────────────────

# Gmail address used to SEND the notification emails
# Tip: you can use Nats' own Gmail, or create a free "sending" Gmail account
EMAIL_USER=your.gmail@gmail.com

# Gmail App Password  ←  NOT your normal Gmail login password
# How to get one (takes 2 minutes):
#   1. Enable 2-Step Verification at: myaccount.google.com/security
#   2. Go to: myaccount.google.com/apppasswords
#   3. Create a new app — name it "Makeup by Nats Website"
#   4. Copy the 16-character password shown and paste it here
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Email address that RECEIVES the enquiry notifications
RECIPIENT_EMAIL=Makeupbynats101@gmail.com

# Port the server listens on (3000 is the default for local development)
PORT=3000
